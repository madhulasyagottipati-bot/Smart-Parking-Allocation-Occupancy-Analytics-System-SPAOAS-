# analytics.py (Week 9 - NumPy Part)

import pandas as pd
import numpy as np


def load_data():
    """
    Load parking slot data from CSV file
    """
    try:
        df = pd.read_csv("data/slots.csv")
        return df

    except FileNotFoundError:
        print("Slots file not found.")
        return None


def occupancy_statistics():
    """
    Calculate occupancy statistics using NumPy
    """

    df = load_data()

    if df is None:
        return

    # Convert status column to NumPy array
    status_array = np.array(df["Status"])

    total_slots = len(status_array)

    free_slots = np.sum(
        status_array == "Free"
    )

    occupied_slots = np.sum(
        status_array == "Occupied"
    )

    reserved_slots = np.sum(
        status_array == "Reserved"
    )

    # Occupancy percentage
    if total_slots > 0:
        occupancy_percentage = (
            occupied_slots / total_slots
        ) * 100
    else:
        occupancy_percentage = 0

    print("\n--- OCCUPANCY STATISTICS ---")

    print("Total Slots:", total_slots)

    print("Free Slots:", free_slots)

    print("Occupied Slots:", occupied_slots)

    print("Reserved Slots:", reserved_slots)

    print(
        "Occupancy Percentage:",
        round(occupancy_percentage, 2),
        "%"
    )
